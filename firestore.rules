rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "oguerichidinmab@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             (!('nickname' in data) || (data.nickname is string && data.nickname.size() < 50)) &&
             (!('grade' in data) || (data.grade is string && data.grade.size() < 20));
    }

    function isValidTask(data) {
      return data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.subject is string && data.subject.size() < 100 &&
             data.type in ['homework', 'test', 'extramural'] &&
             data.completed is bool;
    }

    function isValidCheckIn(data) {
      return data.userId == request.auth.uid &&
             data.mood in ['Happy', 'Stressed', 'Tired', 'Lonely', 'Motivated'] &&
             (!('note' in data) || (data.note is string && data.note.size() < 500));
    }

    function isValidPost(data) {
      return data.userId == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 50 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 2000 &&
             data.category in ['encouragement', 'win', 'tip', 'question'] &&
             data.likes is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }
    
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isDocOwner() && isValidTask(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    match /checkins/{checkinId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidCheckIn(request.resource.data);
    }
    
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        // Owner can update everything
        (isDocOwner() && isValidPost(request.resource.data) && uidNotModified()) ||
        // Others can only update likes
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']))
      );
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
