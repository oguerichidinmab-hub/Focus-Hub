{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "onboarded": { "type": "boolean" },
        "nickname": { "type": "string" },
        "grade": { "type": "string" },
        "strugglingSubjects": { "type": "array", "items": { "type": "string" } },
        "studyGoals": { "type": "array", "items": { "type": "string" } },
        "reminderTimes": { "type": "array", "items": { "type": "string" } },
        "hasExtramural": { "type": "boolean" },
        "supportPreferences": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Task": {
      "title": "Task",
      "description": "Homework, test, or extramural lesson",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "type": { "type": "string", "enum": ["homework", "test", "extramural"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" },
        "lessonTime": { "type": "string" },
        "lessonDays": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "subject", "type", "completed"]
    },
    "CheckIn": {
      "title": "CheckIn",
      "description": "Emotional well-being check-in",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mood": { "type": "string", "enum": ["Happy", "Stressed", "Tired", "Lonely", "Motivated"] },
        "note": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mood", "timestamp"]
    },
    "CommunityPost": {
      "title": "CommunityPost",
      "description": "A post in the peer support community",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["encouragement", "win", "tip", "question"] },
        "likes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "authorName", "content", "category", "likes"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Student tasks and lessons"
    },
    "checkins/{checkinId}": {
      "schema": "CheckIn",
      "description": "Emotional check-ins"
    },
    "posts/{postId}": {
      "schema": "CommunityPost",
      "description": "Community posts"
    }
  }
}
